{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListProjectBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::data-project-m2-master"
    },
    {
      "Sid": "AllowReadWriteObjectsInProjectBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::data-project-m2-master/*"
    },
    {
      "Sid": "DenyAccessToOtherBuckets",
      "Effect": "Deny",
      "Action": [
        "s3:ListBucket",
        "s3:GetObject",
        "s3:PutObject"
      ],
      "NotResource": [
        "arn:aws:s3:::data-project-m2-master",
        "arn:aws:s3:::data-project-m2-master/*"
      ]
    }
  ]
}
